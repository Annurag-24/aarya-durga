# Monorepo-level ignores for backend + frontend

# OS artifacts
.DS_Store
Thumbs.db

# Editor/IDE artifacts
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.swp
*.sw?

# Environment files and secrets
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
**/node_modules/
**/vendor/

# Build/test/cache artifacts
**/dist/
**/dist-ssr/
**/build/
**/coverage/
**/.cache/
**/.vite/
**/.turbo/
**/.phpunit.cache/
**/.phpunit.result.cache

# Laravel runtime artifacts
/aarya-durga-backend/public/hot
/aarya-durga-backend/public/build/
/aarya-durga-backend/storage/*.key
/aarya-durga-backend/storage/pail/

# Local tooling metadata
**/.fleet/
**/.nova/
**/.zed/
**/.phpactor.json

# Local generated outputs
/Aarya-Durga-Frontend/lint_output.txt
